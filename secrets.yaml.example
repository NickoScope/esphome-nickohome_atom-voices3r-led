# -----------------------------------------------------------------------------
# Copy this file to `secrets.yaml` and fill in YOUR OWN values.
# `secrets.yaml` is gitignored and must NEVER be committed.
# -----------------------------------------------------------------------------

wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# 32-byte base64 key for the Home Assistant native API encryption. Generate with:
#   python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
api_encryption_key: "BASE64_32_BYTE_KEY_HERE"

# Over-the-air update password (any strong string you choose)
ota_password: "YOUR_OTA_PASSWORD"

# Fallback hotspot password for the "Atom_Strip" provisioning AP.
# Used when the device can't join your Wi-Fi and starts its own access point
# so you can re-enter network details from a phone. Must be 8+ characters.
ap_password: "YOUR_AP_PASSWORD"
